{
  "expo": {
    "name": "Recipe Keeper",
    "slug": "recipe-keeper",
    "sdkVersion": "54.0.0",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#f4ede0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Recipe Keeper to access your photo library so you can attach recipe images.",
          "cameraPermission": "Allow Recipe Keeper to use your camera so you can take recipe photos."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {},
    "web": {
      "bundler": "metro"
    }
  }
}
