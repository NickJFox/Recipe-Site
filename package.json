{
  "name": "recipe-mobile-app",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "node ./node_modules/expo/bin/cli start --tunnel",
    "start:lan": "node ./node_modules/expo/bin/cli start --lan",
